  private renderNotificationsTab = (): JSX.Element => {
    const { config, isSaving, tempNotifications } = this.state;
    if (!config) return <></>;

    // Use temp state or fallback to config
    const localNotifications = tempNotifications || config.notifications;

    const toggleNotification = (
      role: "manager" | "planner" | "puller" | "deliver" | "shipmentTeam",
      notificationType: ActivityLogType,
    ): void => {
      const currentNotifs = localNotifications[role] || [];
      const newNotifs = currentNotifs.includes(notificationType)
        ? currentNotifs.filter((n) => n !== notificationType)
        : [...currentNotifs, notificationType];

      this.setState({
        tempNotifications: {
          ...localNotifications,
          [role]: newNotifs,
        },
      });
    };

    const renderRoleToggles = (
      role: "manager" | "planner" | "puller" | "deliver" | "shipmentTeam",
      description: string,
    ): JSX.Element => {
      // Define which notification types are locked (disabled & forced off) per role
      const lockedTypes: Partial<
        Record<typeof role, { types: ActivityLogType[]; reason: string }>
      > = {
        planner: {
          types: ["ONE_TIME_DELIVERY_CREATED"],
          reason:
            "One Time Deliveries have no Requester. The creator (Deliver) is notified as the actor.",
        },
        puller: {
          types: ["ONE_TIME_SHIPMENT_CREATED"],
          reason: "Pullers are not involved in One Time Shipments.",
        },
      };

      const locked = lockedTypes[role];
      const lockedTypeSet = new Set(locked?.types || []);

      return (
        <>
          <p
            style={{
              fontSize: 13,
              color: "#605e5c",
              margin: "0 0 16px 0",
              fontStyle: "italic",
            }}
          >
            {description}
          </p>
          <div className={styles.notificationsList}>
            {ALL_NOTIFICATION_TYPES.map((notif) => {
              const isLocked = lockedTypeSet.has(notif.value);
              return (
                <div key={notif.value} className={styles.notificationItem}>
                  <Toggle
                    label={notif.label}
                    checked={
                      isLocked
                        ? false
                        : (localNotifications[role] || []).includes(notif.value)
                    }
                    onChange={() => toggleNotification(role, notif.value)}
                    onText="Enabled"
                    offText="Disabled"
                    disabled={this.props.userRole !== "Manager" || isLocked}
                  />
                  <span className={styles.notificationDesc}>
                    {isLocked ? `🔒 ${locked!.reason}` : notif.description}
                  </span>
                </div>
              );
            })}
          </div>
        </>
      );
    };

    return (
      <div className={styles.tabContent}>
        <div className={styles.sectionHeader}>
          <h3>🔔 Notification Settings</h3>
          <p>
            Configure which notifications each role receives. Select a role tab
            below.
          </p>
        </div>

        <Stack tokens={{ childrenGap: 20 }}>
          {/* Master Notification Toggle */}
          <div
            style={{
              padding: 16,
              background:
                localNotifications.enabled === false ? "#fef2f2" : "#f0fdf4",
              borderRadius: 8,
              border: `1px solid ${localNotifications.enabled === false ? "#fca5a5" : "#86efac"}`,
            }}
          >
            <Toggle
              label="Enable All Notifications"
              checked={localNotifications.enabled !== false}
              onChange={(_e, checked) => {
                this.setState({
                  tempNotifications: {
                    ...localNotifications,
                    enabled: checked,
                  },
                });
              }}
              onText="Notifications are ON — All roles will receive their configured notifications."
              offText="Notifications are OFF — No notifications will be sent to any role."
              disabled={this.props.userRole !== "Manager"}
              styles={{
                root: { marginBottom: 0 },
                label: { fontSize: 16, fontWeight: 700 },
              }}
            />
          </div>

          {/* Role-based Pivot Tabs */}
          <Pivot
            aria-label="Notification settings by role"
            styles={{
              root: { borderBottom: "1px solid #edebe9" },
              link: { fontSize: 14 },
              linkIsSelected: { fontWeight: 600 },
            }}
          >
            <PivotItem headerText="Manager" itemIcon="Admin" itemKey="manager">
              <div style={{ padding: "16px 0" }}>
                {renderRoleToggles(
                  "manager",
                  "All Active Managers receive these notifications.",
                )}
              </div>
            </PivotItem>

            <PivotItem
              headerText="Requester"
              itemIcon="People"
              itemKey="planner"
            >
              <div style={{ padding: "16px 0" }}>
                {renderRoleToggles(
                  "planner",
                  "Specific to each Requester's assigned requests.",
                )}
              </div>
            </PivotItem>

            <PivotItem
              headerText="Puller"
              itemIcon="DeliveryTruck"
              itemKey="puller"
            >
              <div style={{ padding: "16px 0" }}>
                {renderRoleToggles(
                  "puller",
                  "Specific to each Puller. Request Created, Hot Requests, and Complain Added are sent to all Pullers.",
                )}
              </div>
            </PivotItem>

            <PivotItem
              headerText="Deliver"
              itemIcon="Package"
              itemKey="deliver"
            >
              <div style={{ padding: "16px 0" }}>
                {renderRoleToggles(
                  "deliver",
                  "Released for Delivery is for all Deliverers. Others are specific to each Deliverer.",
                )}
              </div>
            </PivotItem>

            <PivotItem
              headerText="Shipment Team"
              itemIcon="Ferry"
              itemKey="shipmentTeam"
            >
              <div style={{ padding: "16px 0" }}>
                {renderRoleToggles(
                  "shipmentTeam",
                  "Specific to Shipment Team members for shipment-related notifications.",
                )}
              </div>
            </PivotItem>
          </Pivot>

          <Stack horizontal tokens={{ childrenGap: 12 }}>
            <PrimaryButton
              text="Save Notification Settings"
              onClick={() => this.saveNotifications(localNotifications)}
              disabled={isSaving || this.props.userRole !== "Manager"}
              iconProps={{ iconName: "Save" }}
            />
            <DefaultButton
              text="Reset"
              onClick={() => this.setState({ tempNotifications: undefined })}
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </Stack>
      </div>
    );
  };

  private renderEditPanel = (): JSX.Element => {
    const {
      editingOption,
      isPanelOpen,
      panelMode,
      currentEditType,
      tempEditOption,
    } = this.state;
    if (!editingOption) return <></>;

    // Use temp state or fallback to editingOption
    const localOption = tempEditOption || editingOption;

    const handleSave = async (): Promise<void> => {
      // 🚫 GUEST CHECK: Guests cannot save system configuration
      if (this.props.currentUser && isGuestUser(this.props.currentUser)) {
        showGuestAlert("save system configuration");
        return;
      }

      // Auto-populate value from label if value is empty
      if (!localOption.value && localOption.label) {
        localOption.value = localOption.label;
      }

      if (currentEditType === "orderType") {
        await this.saveOrderType(localOption);
      } else if (currentEditType === "businessUnit") {
        await this.saveBusinessUnit(localOption);
      } else if (currentEditType === "deliveryLocation") {
        await this.saveDeliveryLocation(localOption);
      } else if (currentEditType === "shipmentLocation") {
        await this.saveShipmentLocation(localOption);
      } else if (currentEditType === "shipmentType") {
        await this.saveShipmentType(localOption);
      } else if (currentEditType === "complainReason") {
        await this.saveComplainReason(localOption);
      } else if (currentEditType === "onHoldReason") {
        await this.saveOnHoldReason(localOption);
      }
      // Clear temp state after save
      this.setState({ tempEditOption: undefined });
    };

    return (
      <Panel
        isOpen={isPanelOpen}
        onDismiss={() =>
          this.setState({
            isPanelOpen: false,
            editingOption: undefined,
            tempEditOption: undefined,
          })
        }
        type={PanelType.medium}
        headerText={`${panelMode === "add" ? "Add" : "Edit"} ${
          currentEditType === "orderType"
            ? "Request Type"
            : currentEditType === "businessUnit"
              ? "Business Unit"
              : currentEditType === "deliveryLocation"
                ? "Delivery Location"
                : currentEditType === "shipmentLocation"
                  ? "Shipment Location"
                  : currentEditType === "complainReason"
                    ? "Complain Reason"
                    : currentEditType === "onHoldReason"
                      ? "On Hold Reason"
                      : ""
        }`}
        closeButtonAriaLabel="Close"
      >
        <Stack tokens={{ childrenGap: 16 }} style={{ marginTop: 20 }}>
          <TextField
            label="Label"
            value={localOption.label}
            onChange={(_, value) =>
              this.setState({
                tempEditOption: {
                  ...localOption,
                  label: value || "",
                  value: value || "",
                },
              })
            }
            required
            description="Display name shown to users"
          />

          <Toggle
            label="Active"
            checked={localOption.isActive}
            onChange={(_, checked) =>
              this.setState({
                tempEditOption: { ...localOption, isActive: !!checked },
              })
            }
            onText="Active"
            offText="Inactive"
          />

          <Stack horizontal tokens={{ childrenGap: 12 }}>
            <PrimaryButton
              text="Save"
              onClick={handleSave}
              iconProps={{ iconName: "Save" }}
            />
            <DefaultButton
              text="Cancel"
              onClick={() =>
                this.setState({ isPanelOpen: false, editingOption: undefined })
              }
            />
          </Stack>
        </Stack>
      </Panel>
    );
  };

  public render(): React.ReactElement<ISystemConfigurationProps> {
    const { isLoading, error, success, activeTab } = this.state;
    console.log(
      "[SystemConfiguration] Rendering - isLoading:",
      isLoading,
      "error:",
      error,
    );

    if (isLoading) {
      return (
        <div className={styles.container}>
          <Spinner size={SpinnerSize.large} label="Loading configuration..." />
        </div>
      );
    }

    return (
      <div className={styles.container}>
        <div className={styles.header}>
          <h1 className={styles.title}>
            <Icon iconName="Settings" />
            System Configuration
          </h1>
          <p className={styles.subtitle}>
            Configure system-wide settings, KPI targets, and notifications
            (Manager Only)
          </p>
        </div>

        {error && (
          <MessageBar
            messageBarType={MessageBarType.error}
            onDismiss={() => this.setState({ error: undefined })}
          >
            {error}
          </MessageBar>
        )}

        {success && (
          <MessageBar
            messageBarType={MessageBarType.success}
            onDismiss={() => this.setState({ success: undefined })}
          >
            {success}
          </MessageBar>
        )}

        <div className={styles.tabs}>
          <button
            className={`${styles.tab} ${
              activeTab === "kpis" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "kpis" })}
          >
            <Icon iconName="BarChartVertical" />
            KPI Targets
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "orderTypes" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "orderTypes" })}
          >
            <Icon iconName="Package" />
            Types
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "businessUnits" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "businessUnits" })}
          >
            <Icon iconName="CityNext" />
            Business Units
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "deliveryLocations" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "deliveryLocations" })}
          >
            <Icon iconName="MapPin" />
            Locations
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "reasonCategories" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "reasonCategories" })}
          >
            <Icon iconName="ClipboardList" />
            Reason Categories
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "notifications" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "notifications" })}
          >
            <Icon iconName="Ringer" />
            Notifications
          </button>
          <button
            className={`${styles.tab} ${
              activeTab === "accessLevels" ? styles.active : ""
            }`}
            onClick={() => this.setState({ activeTab: "accessLevels" })}
          >
            <Icon iconName="Permissions" />
            Access Levels
          </button>
        </div>

        {activeTab === "kpis" && this.renderKPIsTab()}
        {activeTab === "orderTypes" && this.renderOrderTypesTab()}
        {activeTab === "businessUnits" && this.renderBusinessUnitsTab()}
        {activeTab === "deliveryLocations" && this.renderDeliveryLocationsTab()}
        {activeTab === "reasonCategories" && this.renderReasonCategoriesTab()}
        {activeTab === "notifications" && this.renderNotificationsTab()}
        {activeTab === "accessLevels" && this.renderAccessLevelsTab()}

        {this.renderEditPanel()}
      </div>
    );
  }
}
