            <PrimaryButton
              text="Add Shipment Type"
              iconProps={{ iconName: "Add" }}
              onClick={() =>
                this.setState({
                  isPanelOpen: true,
                  panelMode: "add",
                  currentEditType: "shipmentType",
                  editingOption: {
                    id: uuidv4(),
                    label: "",
                    value: "",
                    isActive: true,
                    order: (config.shipmentTypes || []).length + 1,
                  },
                })
              }
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </div>

        <div className={styles.optionsList}>
          {(config.shipmentTypes || []).map((shipmentType) => (
            <div
              key={shipmentType.id}
              className={`${styles.optionCard} ${
                !shipmentType.isActive ? styles.inactive : ""
              }`}
            >
              <div className={styles.optionInfo}>
                <Label className={styles.optionLabel}>
                  {shipmentType.label}
                </Label>
                {!shipmentType.isActive && (
                  <span className={styles.inactiveTag}>Inactive</span>
                )}
              </div>
              <div className={styles.optionActions}>
                <IconButton
                  iconProps={{ iconName: "Edit" }}
                  title="Edit"
                  onClick={() =>
                    this.setState({
                      isPanelOpen: true,
                      panelMode: "edit",
                      currentEditType: "shipmentType",
                      editingOption: shipmentType,
                    })
                  }
                  disabled={isSaving || this.props.userRole !== "Manager"}
                />
                <IconButton
                  iconProps={{ iconName: "Delete" }}
                  title="Deactivate"
                  onClick={() => this.deleteShipmentType(shipmentType.id)}
                  disabled={
                    isSaving ||
                    !shipmentType.isActive ||
                    this.props.userRole !== "Manager"
                  }
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  };

