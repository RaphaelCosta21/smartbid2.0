  private saveAccessLevels = async (
    accessLevels: IAccessLevels,
  ): Promise<void> => {
    // 🚫 GUEST CHECK: Guests cannot save access level settings
    if (this.props.currentUser && isGuestUser(this.props.currentUser)) {
      showGuestAlert("save access level settings");
      return;
    }

    if (!this.configService || !this.props.context) return;

    this.setState({ isSaving: true, error: undefined, success: undefined });

    try {
      const updatedBy = this.props.context.pageContext.user.displayName;
      await this.configService.updateAccessLevels(accessLevels, updatedBy);

      this.setState({
        isSaving: false,
        success: "Access level settings saved successfully!",
        tempAccessLevels: undefined,
      });

      await this.loadConfig();

      setTimeout(() => {
        this.setState({ success: undefined });
      }, 3000);
    } catch (error) {
      this.setState({
        isSaving: false,
        error:
          error instanceof Error
            ? error.message
            : "Failed to save access levels",
      });
    }
  };

  private renderAccessLevelsTab = (): JSX.Element => {
    const { config, isSaving, tempAccessLevels } = this.state;
    if (!config) return <></>;

    const localAccessLevels = tempAccessLevels || config.accessLevels;

    const roles: {
      key: keyof IAccessLevels;
      label: string;
      icon: string;
      description: string;
    }[] = [
      {
        key: "manager",
        label: "Managers",
        icon: "Crown",
        description: "Full system administrators",
      },
      {
        key: "planner",
        label: "Requesters",
        icon: "People",
        description: "Create and manage requests",
      },
      {
        key: "puller",
        label: "Pullers",
        icon: "HandsFree",
        description: "Pick and separate materials",
      },
      {
        key: "deliver",
        label: "Delivers",
        icon: "DeliveryTruck",
        description: "Handle deliveries",
      },
      {
        key: "shipmentTeam",
        label: "Shipment Team",
        icon: "Package",
        description: "Manage shipments and receiving",
      },
      {
        key: "guest",
        label: "Guest / Demo",
        icon: "Guest",
        description: "View-only access for unregistered users",
      },
    ];

    const pages: { key: SmartFlowPage; label: string; icon: string }[] = [
      { key: "workspace", label: "Workspace", icon: "ViewDashboard" },
      { key: "insights", label: "Insights", icon: "Lightbulb" },
      { key: "reports", label: "Reports", icon: "ReportDocument" },
      { key: "settings", label: "Settings", icon: "Settings" },
    ];

    const accessOptions: {
      value: AccessLevel;
      label: string;
      color: string;
    }[] = [
      { value: "edit", label: "View & Edit", color: "#107c10" },
      { value: "view", label: "View Only", color: "#0078d4" },
      { value: "none", label: "No Access", color: "#d13438" },
    ];

    const updateAccess = (
      role: keyof IAccessLevels,
      page: SmartFlowPage,
      level: AccessLevel,
    ): void => {
      // Manager always has full access — cannot be changed
      if (role === "manager") return;

      const currentRoleConfig = localAccessLevels[role] || {
        workspace: "edit",
        insights: "none",
        reports: "edit",
        settings: "view",
      };

      this.setState({
        tempAccessLevels: {
          ...localAccessLevels,
          [role]: {
            ...currentRoleConfig,
            [page]: level,
          },
        },
      });
    };

    const isManager = this.props.userRole === "Manager";

    return (
      <div className={styles.tabContent}>
        <div className={styles.sectionHeader}>
          <h3>🔐 Access Levels Configuration</h3>
          <p>
            Define which roles can access each page and their permission level.
            Only Managers can modify these settings.
          </p>
        </div>

        <div className={styles.accessLevelsGrid}>
          {/* Header row */}
          <div className={styles.accessGridHeader}>
            <div className={styles.accessGridRoleHeader}>Role</div>
            {pages.map((page) => (
              <div key={page.key} className={styles.accessGridPageHeader}>
                <Icon iconName={page.icon} />
                <span>{page.label}</span>
              </div>
            ))}
          </div>

          {/* Role rows */}
          {roles.map((role) => {
            const roleAccess: IRoleAccessConfig = localAccessLevels[
              role.key
            ] || {
              workspace: "edit",
              insights: "none",
              reports: "edit",
              settings: "view",
            };
            const isManagerRole = role.key === "manager";

            return (
              <div
                key={role.key}
                className={`${styles.accessGridRow} ${isManagerRole ? styles.accessGridRowManager : ""}`}
              >
                <div className={styles.accessGridRoleCell}>
                  <div className={styles.accessRoleInfo}>
                    <Icon
                      iconName={role.icon}
                      className={styles.accessRoleIcon}
                    />
                    <div>
                      <span className={styles.accessRoleName}>
                        {role.label}
                      </span>
                      <span className={styles.accessRoleDesc}>
                        {role.description}
                      </span>
                    </div>
                  </div>
                  {isManagerRole && (
                    <span className={styles.accessLockedBadge}>
                      <Icon iconName="Lock" /> Full Access
                    </span>
                  )}
                </div>

                {pages.map((page) => {
                  const currentLevel = roleAccess[page.key];
                  const currentOption = accessOptions.find(
                    (o) => o.value === currentLevel,
                  );

                  return (
                    <div key={page.key} className={styles.accessGridCell}>
                      {isManagerRole ? (
                        <span
                          className={styles.accessBadge}
                          style={{ backgroundColor: "#107c10", color: "white" }}
                        >
                          View & Edit
                        </span>
                      ) : (
                        <div className={styles.accessDropdown}>
                          <select
                            value={currentLevel}
                            onChange={(e) =>
                              updateAccess(
                                role.key,
                                page.key,
                                e.target.value as AccessLevel,
                              )
                            }
                            disabled={!isManager || isSaving}
                            className={styles.accessSelect}
                            style={{
                              borderColor: currentOption?.color || "#605e5c",
                            }}
                          >
                            {accessOptions.map((opt) => (
                              <option key={opt.value} value={opt.value}>
                                {opt.label}
                              </option>
                            ))}
                          </select>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            );
          })}
        </div>

        {/* Legend */}
        <div className={styles.accessLegend}>
          {accessOptions.map((opt) => (
            <div key={opt.value} className={styles.accessLegendItem}>
              <span
                className={styles.accessLegendDot}
                style={{ backgroundColor: opt.color }}
              />
              <span className={styles.accessLegendLabel}>
                <strong>{opt.label}</strong>
                {opt.value === "edit" && " — Can view and modify content"}
                {opt.value === "view" &&
                  " — Can see content but cannot make changes"}
                {opt.value === "none" &&
                  " — Cannot access the page (visible but disabled)"}
              </span>
            </div>
          ))}
        </div>

        <Stack
          horizontal
          tokens={{ childrenGap: 12 }}
          style={{ marginTop: 24 }}
        >
          <PrimaryButton
            text="Save Access Levels"
            onClick={() => this.saveAccessLevels(localAccessLevels)}
            disabled={isSaving || !isManager}
            iconProps={{ iconName: "Save" }}
          />
          <DefaultButton
            text="Reset"
            onClick={() => this.setState({ tempAccessLevels: undefined })}
            disabled={isSaving || !isManager}
          />
        </Stack>

        {/* ── Request Creation Access Levels ── */}
        {this.renderRequestAccessLevelsSection(isManager)}
      </div>
    );
  };

  private saveRequestAccessLevels = async (
    requestAccessLevels: IRequestAccessConfig,
  ): Promise<void> => {
    if (this.props.currentUser && isGuestUser(this.props.currentUser)) {
      showGuestAlert("save request access settings");
      return;
    }

    if (!this.configService || !this.props.context) return;

    this.setState({ isSaving: true, error: undefined, success: undefined });

    try {
      const updatedBy = this.props.context.pageContext.user.displayName;
      await this.configService.updateRequestAccessLevels(
        requestAccessLevels,
        updatedBy,
      );

      this.setState({
        isSaving: false,
        success: "Request access level settings saved successfully!",
        tempRequestAccessLevels: undefined,
      });

      await this.loadConfig();

      setTimeout(() => {
        this.setState({ success: undefined });
      }, 3000);
    } catch (error) {
      this.setState({
        isSaving: false,
        error:
          error instanceof Error
            ? error.message
            : "Failed to save request access levels",
      });
    }
  };

  private renderRequestAccessLevelsSection = (
    isManager: boolean,
  ): JSX.Element => {
    const { config, isSaving, tempRequestAccessLevels } = this.state;
    if (!config) return <></>;

    const localRequestAccess =
      tempRequestAccessLevels ||
      config.requestAccessLevels ||
      DEFAULT_SYSTEM_CONFIG.requestAccessLevels!;

    const requestTypes: {
      key: keyof IRequestAccessConfig;
      label: string;
      icon: string;
    }[] = [
      {
        key: "deliveryRequest",
        label: "Delivery Request",
        icon: "Sync",
      },
      {
        key: "oneTimeDelivery",
        label: "One Time Delivery",
        icon: "DeliveryTruck",
      },
      {
        key: "shipmentRequest",
        label: "Shipment Request",
        icon: "ClipboardList",
      },
      {
        key: "oneTimeShipment",
        label: "One Time Shipment",
        icon: "Mail",
      },
    ];

    const allRoles = [
      { key: "manager", label: "Manager" },
      { key: "planner", label: "Requester" },
      { key: "puller", label: "Puller" },
      { key: "deliver", label: "Deliver" },
      { key: "shipmentTeam", label: "Shipment Team" },
    ];

    const toggleRole = (
      requestType: keyof IRequestAccessConfig,
      role: string,
    ): void => {
      if (role === "manager") return; // Manager always has access
      const current = [...(localRequestAccess[requestType] || [])];
      const idx = current.indexOf(role);
      if (idx >= 0) {
        current.splice(idx, 1);
      } else {
        current.push(role);
      }
      this.setState({
        tempRequestAccessLevels: {
          ...localRequestAccess,
          [requestType]: current,
        },
      });
    };

    return (
      <>
        <Separator style={{ margin: "32px 0 16px 0" }} />
        <div className={styles.sectionHeader}>
          <h3>📋 Request Creation Access</h3>
          <p>
            Control which roles can create each request type. Manager always has
            access to all request types.
          </p>
        </div>

        <div
          style={{
            display: "grid",
            gridTemplateColumns: "180px repeat(5, 1fr)",
            gap: 0,
            border: "1px solid #edebe9",
            borderRadius: 8,
            overflow: "hidden",
          }}
        >
          {/* Header row */}
          <div
            style={{
              padding: "12px 16px",
              fontWeight: 600,
              backgroundColor: "#f5f5f5",
              borderBottom: "2px solid #e1e1e1",
              fontSize: 12,
              textTransform: "uppercase",
              color: "#323130",
            }}
          >
            Request Type
          </div>
          {allRoles.map((role) => (
            <div
              key={role.key}
              style={{
                padding: "12px 8px",
                fontWeight: 600,
                backgroundColor: "#f5f5f5",
                borderBottom: "2px solid #e1e1e1",
                fontSize: 12,
                textTransform: "uppercase",
                color: "#323130",
                textAlign: "center",
              }}
            >
              {role.label}
            </div>
          ))}

          {/* Data rows */}
          {requestTypes.map((rt, rtIndex) => (
            <React.Fragment key={rt.key}>
              <div
                style={{
                  padding: "12px 16px",
                  display: "flex",
                  alignItems: "center",
                  gap: 8,
                  borderBottom:
                    rtIndex < requestTypes.length - 1
                      ? "1px solid #edebe9"
                      : "none",
                  backgroundColor: rtIndex % 2 === 0 ? "#fff" : "#fafafa",
                }}
              >
                <Icon iconName={rt.icon} style={{ fontSize: 16 }} />
                <span style={{ fontWeight: 500, fontSize: 13 }}>
                  {rt.label}
                </span>
              </div>
              {allRoles.map((role) => {
                const isAllowed =
                  localRequestAccess[rt.key]?.includes(role.key) ?? false;
                const isManagerRole = role.key === "manager";

                // Lock Planner for One Time Delivery, Puller for One Time Shipment
                const isLocked =
                  (rt.key === "oneTimeDelivery" && role.key === "planner") ||
                  (rt.key === "oneTimeShipment" && role.key === "puller");

                const lockedReason =
                  rt.key === "oneTimeDelivery" && role.key === "planner"
                    ? "One Time Deliveries have no Requester"
                    : rt.key === "oneTimeShipment" && role.key === "puller"
                      ? "Pullers are not involved in One Time Shipments"
                      : "";

                return (
                  <div
                    key={role.key}
                    style={{
                      padding: "12px 8px",
                      textAlign: "center",
                      borderBottom:
                        rtIndex < requestTypes.length - 1
                          ? "1px solid #edebe9"
                          : "none",
                      backgroundColor: rtIndex % 2 === 0 ? "#fff" : "#fafafa",
                    }}
                  >
                    {isManagerRole ? (
                      <span
                        style={{
                          display: "inline-block",
                          padding: "4px 10px",
                          borderRadius: 4,
                          backgroundColor: "#107c10",
                          color: "white",
                          fontSize: 11,
                          fontWeight: 600,
                        }}
                      >
                        Always
                      </span>
                    ) : isLocked ? (
                      <span
                        title={lockedReason}
                        style={{
                          display: "inline-block",
                          padding: "4px 10px",
                          borderRadius: 4,
                          backgroundColor: "#d2d0ce",
                          color: "#605e5c",
                          fontSize: 11,
                          fontWeight: 600,
                          cursor: "help",
                        }}
                      >
                        🔒 Blocked
                      </span>
                    ) : (
                      <Toggle
                        checked={isAllowed}
                        onChange={() => toggleRole(rt.key, role.key)}
                        disabled={!isManager || isSaving}
                        styles={{
                          root: {
                            margin: "0 auto",
                            display: "flex",
                            justifyContent: "center",
                          },
                        }}
                      />
                    )}
                  </div>
                );
              })}
            </React.Fragment>
          ))}
        </div>

        <Stack
          horizontal
          tokens={{ childrenGap: 12 }}
          style={{ marginTop: 16 }}
        >
          <PrimaryButton
            text="Save Request Access"
            onClick={() => this.saveRequestAccessLevels(localRequestAccess)}
            disabled={isSaving || !isManager}
            iconProps={{ iconName: "Save" }}
          />
          <DefaultButton
            text="Reset"
            onClick={() =>
              this.setState({ tempRequestAccessLevels: undefined })
            }
            disabled={isSaving || !isManager}
          />
        </Stack>
      </>
    );
  };

  private renderKPIsTab = (): JSX.Element => {
    const { config, isSaving, tempKpiTargets } = this.state;
    if (!config) return <></>;

    // Use temp state or fallback to config
    const localTargets = tempKpiTargets || config.kpiTargets;

    return (
      <div className={styles.tabContent}>
        <div className={styles.sectionHeader}>
          <h3>📊 KPI Targets Configuration</h3>
          <p>
            Define the target values for key performance indicators across the
            warehouse.
          </p>
        </div>

        <Stack tokens={{ childrenGap: 20 }}>
          <TextField
            label="Target OTIF (%)"
            type="number"
            min={0}
            max={100}
            value={localTargets.targetOTIF.toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetOTIF: parseInt(value || "0"),
                },
              })
            }
            description="On-Time In-Full percentage target (e.g., 85)"
            suffix="%"
            disabled={this.props.userRole !== "Manager"}
          />

          <TextField
            label="Target Accuracy Rate (%)"
            type="number"
            min={0}
            max={100}
            value={localTargets.targetAccuracyRate.toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetAccuracyRate: parseInt(value || "0"),
                },
              })
            }
            description="Pull accuracy percentage target (e.g., 98)"
            suffix="%"
            disabled={this.props.userRole !== "Manager"}
          />

          <TextField
            label="Target On-Time Delivery (%)"
            type="number"
            min={0}
            max={100}
            value={localTargets.targetOnTimeDelivery.toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetOnTimeDelivery: parseInt(value || "0"),
                },
              })
            }
            description="On-time delivery percentage target (e.g., 90)"
            suffix="%"
            disabled={this.props.userRole !== "Manager"}
          />

          <TextField
            label="Target Cancellation Rate (%)"
            type="number"
            min={0}
            max={100}
            value={(localTargets.targetCancellationRate || 5).toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetCancellationRate: parseInt(value || "5"),
                },
              })
            }
            description="Maximum acceptable cancellation rate percentage (e.g., 5). Lower is better."
            suffix="%"
            disabled={this.props.userRole !== "Manager"}
          />

          <TextField
            label="Target Avg Assignment Time (minutes)"
            type="number"
            min={0}
            value={(localTargets.targetAvgAssignmentTime || 30).toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetAvgAssignmentTime: parseInt(value || "30"),
                },
              })
            }
            description="Target average time from order creation to puller assignment in minutes (e.g., 30). Lower is better."
            suffix="min"
            disabled={this.props.userRole !== "Manager"}
          />

          <TextField
            label="Target < 2/3 Days Notice Rate (%)"
            type="number"
            min={0}
            max={100}
            value={(localTargets.targetShortNoticeRate || 15).toString()}
            onChange={(_, value) =>
              this.setState({
                tempKpiTargets: {
                  ...localTargets,
                  targetShortNoticeRate: parseInt(value || "15"),
                },
              })
            }
            description="Maximum acceptable short notice rate percentage (e.g., 15). Orders with < 2 days (Delivery) or < 3 days (Shipment) notice. Lower is better."
            suffix="%"
            disabled={this.props.userRole !== "Manager"}
          />

          <Stack horizontal tokens={{ childrenGap: 12 }}>
            <PrimaryButton
              text="Save KPI Targets"
              onClick={() => this.saveKPITargets(localTargets)}
              disabled={isSaving || this.props.userRole !== "Manager"}
              iconProps={{ iconName: "Save" }}
            />
            <DefaultButton
              text="Reset"
              onClick={() => this.setState({ tempKpiTargets: undefined })}
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </Stack>
      </div>
    );
  };

  private renderOrderTypesTab = (): JSX.Element => {
