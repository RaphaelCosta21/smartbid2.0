                this.setState({
                  isPanelOpen: true,
                  panelMode: "add",
                  currentEditType: "shipmentLocation",
                  editingOption: {
                    id: uuidv4(),
                    label: "",
                    value: "",
                    isActive: true,
                    order: shipmentLocations.length + 1,
                  },
                })
              }
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </div>

        <div className={styles.optionsList}>
          {shipmentLocations.map((location) => (
            <div
              key={location.id}
              className={`${styles.optionCard} ${
                !location.isActive ? styles.inactive : ""
              }`}
            >
              <div className={styles.optionInfo}>
                <Label className={styles.optionLabel}>{location.label}</Label>
                {!location.isActive && (
                  <span className={styles.inactiveTag}>Inactive</span>
                )}
              </div>
              <div className={styles.optionActions}>
                <IconButton
                  iconProps={{ iconName: "Edit" }}
                  title="Edit"
                  onClick={() =>
                    this.setState({
                      isPanelOpen: true,
                      panelMode: "edit",
                      currentEditType: "shipmentLocation",
                      editingOption: location,
                    })
                  }
                  disabled={isSaving || this.props.userRole !== "Manager"}
                />
                <IconButton
                  iconProps={{ iconName: "Delete" }}
                  title="Deactivate"
                  onClick={() => this.deleteShipmentLocation(location.id)}
                  disabled={
                    isSaving ||
                    !location.isActive ||
                    this.props.userRole !== "Manager"
                  }
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    );
  };

  private renderReasonCategoriesTab = (): JSX.Element => {
