export class SystemConfiguration extends React.Component<
  ISystemConfigurationProps,
  ISystemConfigurationState
> {
  private configService: SystemConfigService | null = null;

  constructor(props: ISystemConfigurationProps) {
    super(props);
    console.log("[SystemConfiguration] Constructor called with props:", props);

    this.state = {
      config: undefined,
      isLoading: true,
      isSaving: false,
      error: undefined,
      success: undefined,
      activeTab: "kpis",
      editingOption: undefined,
      isPanelOpen: false,
      panelMode: "add",
      currentEditType: undefined,
      tempKpiTargets: undefined,
      tempNotifications: undefined,
      tempEditOption: undefined,
      tempAccessLevels: undefined,
      tempRequestAccessLevels: undefined,
    };
  }

  public async componentDidMount(): Promise<void> {
    console.log("[SystemConfiguration] componentDidMount - loading config");
    await this.loadConfig();
  }

  private loadConfig = async (): Promise<void> => {
    console.log("[SystemConfiguration] loadConfig started");
    this.setState({ isLoading: true, error: undefined });

    try {
      if (this.props.context) {
        console.log(
          "[SystemConfiguration] Creating SystemConfigService with context",
        );
        this.configService = new SystemConfigService(this.props.context);
        console.log("[SystemConfiguration] Fetching system config...");
        const config = await this.configService.getSystemConfig();
        console.log("[SystemConfiguration] Config loaded:", config);
        this.setState({ config, isLoading: false });
      } else {
        console.error("[SystemConfiguration] No context available!");
        // Modo sem contexto (fallback para desenvolvimento)
        this.setState({
          config: undefined,
          isLoading: false,
          error:
            "Context not available. This page requires SharePoint context.",
        });
      }
    } catch (error) {
      console.error("[SystemConfiguration] Error loading config:", error);
      this.setState({
        isLoading: false,
        error:
          error instanceof Error
            ? error.message
            : "Failed to load configuration",
      });
    }
  };

  private saveKPITargets = async (targets: IKPITargets): Promise<void> => {
    // 🚫 GUEST CHECK: Guests cannot save KPI targets
    if (this.props.currentUser && isGuestUser(this.props.currentUser)) {
      showGuestAlert("save KPI targets");
      return;
    }

    if (!this.configService || !this.props.context) return;

    this.setState({ isSaving: true, error: undefined, success: undefined });

    try {
      const updatedBy = this.props.context.pageContext.user.displayName;
      await this.configService.updateKPITargets(targets, updatedBy);

      this.setState({
        isSaving: false,
        success: "KPI targets updated successfully!",
      });

      // Reload config
      await this.loadConfig();

      // Clear success message after 3 seconds
      setTimeout(() => {
        this.setState({ success: undefined });
      }, 3000);
    } catch (error) {
      this.setState({
        isSaving: false,
        error:
          error instanceof Error ? error.message : "Failed to save KPI targets",
      });
    }
  };

  private saveOrderType = async (orderType: IConfigOption): Promise<void> => {
    if (!this.configService || !this.props.context) return;

    this.setState({ isSaving: true, error: undefined, success: undefined });

    try {
      const updatedBy = this.props.context.pageContext.user.displayName;
      await this.configService.saveOrderType(orderType, updatedBy);

      this.setState({
        isSaving: false,
        success: "Order type saved successfully!",
        isPanelOpen: false,
        editingOption: undefined,
      });

      await this.loadConfig();

      setTimeout(() => {
        this.setState({ success: undefined });
      }, 3000);
    } catch (error) {
      this.setState({
        isSaving: false,
        error:
          error instanceof Error ? error.message : "Failed to save order type",
      });
    }
  };

  private deleteOrderType = async (orderTypeId: string): Promise<void> => {
    if (!this.configService || !this.props.context) return;

    if (!confirm("Are you sure you want to deactivate this order type?"))
      return;

    this.setState({ isSaving: true, error: undefined, success: undefined });

    try {
      const updatedBy = this.props.context.pageContext.user.displayName;
      await this.configService.deleteOrderType(orderTypeId, updatedBy);

      this.setState({
        isSaving: false,
        success: "Order type deactivated successfully!",
      });

      await this.loadConfig();

      setTimeout(() => {
        this.setState({ success: undefined });
      }, 3000);
    } catch (error) {
      this.setState({
        isSaving: false,
        error:
          error instanceof Error
            ? error.message
            : "Failed to delete order type",
      });
    }
  };

