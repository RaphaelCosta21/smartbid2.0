/**
 * System Configuration Component
 * Manager-only page to configure KPI targets, order types, business units, and notifications
 */

import * as React from "react";
import {
  Stack,
  TextField,
  PrimaryButton,
  DefaultButton,
  Label,
  MessageBar,
  MessageBarType,
  Spinner,
  SpinnerSize,
  IconButton,
  Toggle,
  Separator,
  Panel,
  PanelType,
  Icon,
  Pivot,
  PivotItem,
} from "@fluentui/react";
import { WebPartContext } from "@microsoft/sp-webpart-base";
import { SystemConfigService } from "../../services/SystemConfigService";
import {
  ISystemConfig,
  IKPITargets,
  IConfigOption,
  IRoleNotifications,
  IAccessLevels,
  IRequestAccessConfig,
  AccessLevel,
  SmartFlowPage,
  IRoleAccessConfig,
  DEFAULT_SYSTEM_CONFIG,
} from "../../models/ISystemConfig";
import { ITeamMember } from "../../models/ITeamMember";
import { ActivityLogType } from "../../models/IActivityLog";
import { isGuestUser, showGuestAlert } from "../../utils/userUtils";
import { v4 as uuidv4 } from "uuid";
import styles from "./SystemConfiguration.module.scss";

export interface ISystemConfigurationProps {
  context?: WebPartContext;
  currentUser?: ITeamMember;
  userRole?: string;
}

interface ISystemConfigurationState {
  config: ISystemConfig | undefined;
  isLoading: boolean;
  isSaving: boolean;
  error: string | undefined;
  success: string | undefined;
  activeTab:
    | "kpis"
    | "orderTypes"
    | "businessUnits"
    | "deliveryLocations"
    | "reasonCategories"
    | "notifications"
    | "accessLevels";
  editingOption: IConfigOption | undefined;
  isPanelOpen: boolean;
  panelMode: "add" | "edit";
  currentEditType:
    | "orderType"
    | "businessUnit"
    | "deliveryLocation"
    | "shipmentLocation"
    | "shipmentType"
    | "complainReason"
    | "onHoldReason"
    | undefined;
  // Temporary edit states
  tempKpiTargets: IKPITargets | undefined;
  tempNotifications: IRoleNotifications | undefined;
  tempEditOption: IConfigOption | undefined;
  tempAccessLevels: IAccessLevels | undefined;
  tempRequestAccessLevels: IRequestAccessConfig | undefined;
}

