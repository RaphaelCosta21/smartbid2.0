        {/* Complain Reasons Section */}
        <div className={styles.sectionHeader}>
          <Stack
            horizontal
            horizontalAlign="space-between"
            verticalAlign="center"
          >
            <div>
              <h3>⚠️ Complain Reasons</h3>
              <p>
                Manage available reasons for complaints registered by
                requesters.
              </p>
            </div>
            <PrimaryButton
              text="Add Complain Reason"
              iconProps={{ iconName: "Add" }}
              onClick={() =>
                this.setState({
                  isPanelOpen: true,
                  panelMode: "add",
                  currentEditType: "complainReason",
                  editingOption: {
                    id: uuidv4(),
                    label: "",
                    value: "",
                    isActive: true,
                    order: config.complainReasons.length + 1,
                  },
                })
              }
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </div>

        <div className={styles.optionsList}>
          {config.complainReasons.map((reason) => (
            <div
              key={reason.id}
              className={`${styles.optionCard} ${
                !reason.isActive ? styles.inactive : ""
              }`}
            >
              <div className={styles.optionInfo}>
                <Label className={styles.optionLabel}>{reason.label}</Label>
                {!reason.isActive && (
                  <span className={styles.inactiveTag}>Inactive</span>
                )}
              </div>
              <div className={styles.optionActions}>
                <IconButton
                  iconProps={{ iconName: "Edit" }}
                  title="Edit"
                  onClick={() =>
                    this.setState({
                      isPanelOpen: true,
                      panelMode: "edit",
                      currentEditType: "complainReason",
                      editingOption: reason,
                    })
                  }
                  disabled={isSaving || this.props.userRole !== "Manager"}
                />
                <IconButton
                  iconProps={{ iconName: "Delete" }}
                  title="Deactivate"
                  onClick={() => this.deleteComplainReason(reason.id)}
                  disabled={
                    isSaving ||
                    !reason.isActive ||
                    this.props.userRole !== "Manager"
                  }
                />
              </div>
            </div>
          ))}
        </div>

        <Separator />

        {/* On Hold Reasons Section */}
        <div className={styles.sectionHeader} style={{ marginTop: 24 }}>
          <Stack
            horizontal
            horizontalAlign="space-between"
            verticalAlign="center"
          >
            <div>
              <h3>⏸️ On Hold Reasons</h3>
              <p>Manage available reasons for placing requests on hold.</p>
            </div>
            <PrimaryButton
              text="Add On Hold Reason"
              iconProps={{ iconName: "Add" }}
              onClick={() =>
                this.setState({
                  isPanelOpen: true,
                  panelMode: "add",
                  currentEditType: "onHoldReason",
                  editingOption: {
                    id: uuidv4(),
                    label: "",
                    value: "",
                    isActive: true,
                    order: config.onHoldReasons.length + 1,
                  },
                })
              }
              disabled={isSaving || this.props.userRole !== "Manager"}
            />
          </Stack>
        </div>

        <div className={styles.optionsList}>
          {config.onHoldReasons.map((reason) => (
            <div
              key={reason.id}
              className={`${styles.optionCard} ${
                !reason.isActive ? styles.inactive : ""
              }`}
            >
              <div className={styles.optionInfo}>
                <Label className={styles.optionLabel}>{reason.label}</Label>
                {!reason.isActive && (
                  <span className={styles.inactiveTag}>Inactive</span>
                )}
              </div>
              <div className={styles.optionActions}>
                <IconButton
                  iconProps={{ iconName: "Edit" }}
